<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

    <t t-name="school_base.PaymentDialog">

        <Dialog title="'Pay Tuition Fee'">

            <div class="container-fluid">

                <div class="row mb-3">
                    <div class="col-4 fw-semibold">Student</div>
                    <div class="col-8">
                        <t t-esc="props.studentName"/>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-4 fw-semibold">Month</div>
                    <div class="col-8">
                        <t t-esc="monthName"/>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-4 fw-semibold">Due Amount</div>
                    <div class="col-8 text-danger fw-bold">
                        ৳<t t-esc="dueAmount"/>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Payment Method</label>

                    <select class="form-select" t-on-change="onMethodChange">
                        <option value="">Select Payment Method</option>
                        
                        <option
                            t-foreach="state.paymentMethods"
                            t-as="method"
                            t-key="method.id"
                            t-att-value="method.id"

                        >   
                            <t t-esc="method.name"/>
                        </option>
                    </select>
                </div>

                <div class="mb-2">
                    <label class="form-label fw-semibold">Amount to Pay</label>

                    <input
                        type="number"
                        class="form-control"
                        t-att-value="state.amountToPay"
                        t-on-input="onAmountChange"/>
                </div>

                <div class="text-muted small mb-4">
                    Maximum Payable : <strong>৳<t t-esc="dueAmount"/></strong>
                </div>

                <div class="d-flex justify-content-end">
                    <button class="btn btn-secondary me-2" t-on-click="props.close">
                        Cancel
                    </button>

                    <button class="btn btn-success" t-on-click="payNow">
                        <i class="fa fa-credit-card me-1"/>
                        Pay Now
                    </button>
                </div>

            </div>

        </Dialog>

    </t>

</templates>