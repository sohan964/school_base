<templates>
    <t t-name="school_base.KpiCard" school_base="1">
        <div class="col-12 col-sm-6 col-md-3">
            
            <div t-attf-class="card kpi-card text-white #{props.bg} shadow border-0 h-100">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <!-- Left Content -->
                    <div>
                        <h6 class="text-white-50 mb-1" t-esc="props.name"/>
                        <h2 class="fw-bold  mb-0">
                            <span class="text-white" t-esc="props.value"/>
                        </h2>
                    </div>

                    <!-- Right Icon -->
                    <div class="opacity-50">
                        <i t-attf-class="bi #{props.icon} fs-1"></i>
                    </div>

                </div>

            </div>

        </div>
    </t>
</templates>