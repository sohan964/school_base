<templates xml:space="preserve">
    <t t-name="school_base.SchoolTeacherDashboard" school_base="1">
        <div class="vh-100 overflow-auto">
            <div class="row">
                <div class="col-12 col-md-10 mx-auto p-4">
                    <!-- HEADER -->
                    <div class="card soft-card shadow-sm border-0 mb-4">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <!-- LEFT (Text) -->
                                <div class="col-12 col-md-8">
                                    <h5 class="fw-semibold mb-1">
                                        👋 Welcome back,
                                        <span t-esc="state.teacherinfo.name"/>
                                    </h5>
                                    <div class="text-muted small">
                                        <span t-esc="state.teacherinfo.designation"/> ·
                                        <span t-esc="state.teacherinfo.department"/>
                                    </div>
                                </div>
                                <!-- RIGHT (Date + Avatar) -->
                                <div class="col-12 col-md-4 mt-3 mt-md-0">
                                    <div class="d-flex align-items-center justify-content-between justify-content-md-end">
                                        <!-- Date -->
                                        <div class="text-md-end">
                                            <div class="fw-medium">Accademic Year</div>
                                            <small class="text-muted">
                                                <span t-esc="state.accademic_year.name"/>
                                            </small>
                                        </div>
                                        <!-- Avatar -->
                                        <img 
                                            t-att-src="state.teacherinfo.image 
                                                ? 'data:image/jpeg;base64,' + state.teacherinfo.image 
                                                : 'https://via.placeholder.com/45'"
                                            class="rounded-circle border shadow-sm ms-3"
                                            width="45"
                                            height="45"
                                        />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">
                        <!-- LEFT: Schedule -->
                        <div class="col-lg-6">
                            <div class="card soft-card mb-3">

    <div class="card-header d-flex justify-content-between align-items-center">

        <span class="fw-semibold">

            <t t-if="state.schedules.viewMode === 'today'">
                <t t-esc="state.schedules.today"/>'s Schedule
            </t>

            <t t-if="state.schedules.viewMode === 'week'">
                Weekly Schedule
            </t>

        </span>

        <select
            class="form-select form-select-sm"
            style="width:120px;"
            t-on-change="onRoutineViewChange">

            <option value="today">
                Today
            </option>

            <option value="week">
                This Week
            </option>

        </select>

    </div>

    <div class="card-body p-0">

        <table class="table table-hover mb-0">

            <thead class="table-light">

                <tr>

                    <th t-if="state.schedules.viewMode === 'week'">
                        Day
                    </th>

                    <th>
                        Class
                    </th>

                    <th>
                        Section
                    </th>

                    <th>
                        Subject
                    </th>
                    <th>
                        Time
                    </th>

                </tr>

            </thead>

            <tbody>

                <tr t-if="!state.teacherroutine.length">

                    <td
                        t-att-colspan="state.schedules.viewMode === 'week' ? 5 : 4"
                        class="text-center text-muted">

                        No Schedule Found

                    </td>

                </tr>

                <tr
                    t-foreach="state.teacherroutine"
                    t-as="routine"
                    t-key="routine.id">

                    <td t-if="state.schedules.viewMode === 'week'">

                        <t t-esc="routine.day_id[1]"/>

                    </td>

                    <td>

                        <t t-esc="routine.class_id[1]"/>

                    </td>

                    <td>

                        <t t-esc="routine.section_id[1]"/>

                    </td>

                    <td>

                        <t t-esc="routine.subject_id[1]"/>

                    </td>
                    <td>

                        <t t-esc="routine.slot_id[1]"/>

                    </td>

                </tr>

            </tbody>

        </table>

    </div>

</div>
                            <div>
                                <div class="card soft-card  text-center">
                                    <h2 class="fw-bold" t-esc="state.all_student +' Students'"></h2>
                                    <div >
                                        <ChartRenderer t-props="{
                                            type: 'bar',
                                            data: state.chartData,
                                            options: {
                                                responsive: true,
                                                maintainAspectRatio: false,

                                                plugins: {
                                                    legend: { position: 'top' },
                                                    title: {
                                                        display: true,
                                                        text: &quot;Today's Class Attendance&quot;
                                                    }
                                                },

                                                scales: {
                                                    x: {
                                                        grid: { display: false }
                                                    },
                                                    y: {
                                                        beginAtZero: true,
                                                        ticks: {
                                                            stepSize: 10
                                                        }
                                                    }
                                                }
                                            }
                                        }"/>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3">
                                <div class="card soft-card p-3">
                                <h6 class="fw-semibold">Exam Tasks</h6>
                                <div class="task-item">
                                    Math Exam
                                    <span class="badge bg-warning">Schedule</span>
                                </div>
                                <div class="task-item">
                                    Submit Results
                                    <span class="badge bg-primary">Submit</span>
                                </div>
                            </div>
                            </div>
                            
                        </div>
                        <!-- RIGHT: Attendance -->
                        <!-- Attendance -->
                        <div class="col-lg-6 ">
                            <div class="card soft-card ">
                                <!-- Header -->
                                <div class="card-header fw-semibold">
                                    Today's Attendance
                                </div>
                                <!-- Body -->
                                <div class="card-body">
                                    <div class="row g-3 align-items-center">
                                        <!-- LEFT: Cards -->
                                        <div class="col-12 col-md-6">
                                            <div class="d-flex flex-column gap-3">
                                                <div class="card kpi-card text-white bg-primary shadow border-0 h-100">
                                                    <div class="card-body d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <h6 class="text-white mb-1">Scheduled</h6>
                                                            <h2 class="fw-bold  mb-0">
                                                                <span class="text-white-100" t-esc="state.schedules.totalToday"></span>
                                                            </h2>
                                                        </div>
                                                        <div class="opacity-50">
                                                            <i class="bi bi-calendar-check"></i>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="card kpi-card text-white bg-success shadow border-0 h-100">
                                                    <div class="card-body d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <h6 class="text-white mb-1">Taken</h6>
                                                            <h2 class="fw-bold  mb-0">
                                                                <span class="text-white-100" t-esc="state.schedules.taken"></span>
                                                            </h2>
                                                        </div>
                                                        <div class="opacity-50">
                                                            <i class="bi bi-check-circle"></i>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="card kpi-card text-white bg-warning shadow border-0 h-100">
                                                    <div class="card-body d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <h6 class="text-white mb-1">Pending</h6>
                                                            <h2 class="fw-bold  mb-0">
                                                                <span class="text-white-100" t-esc="state.schedules.pending"></span>
                                                            </h2>
                                                        </div>
                                                        <div class="opacity-50">
                                                            <i class="bi bi-clock"></i>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <div class="d-flex justify-content-center align-items-center ">
                                                <div >
                                                    <ChartRenderer t-props="{
                                                        type: 'doughnut',
                                                        data: {
                                                            labels: ['Taken', 'Pending'],
                                                            datasets: [{
                                                                label: 'Total Class ' + state.schedules.totalToday,
                                                                data: [state.schedules.taken, state.schedules.pending],
                                                                backgroundColor: [
                                                                    '#28a745',
                                                                    '#ffc107'
                                                                ]
                                                            }]
                                                        },
                                                        options: {
                                                            plugins: {
                                                                legend: { position: 'bottom' },
                                                                title: { 
                                                                    display: true, 
                                                                    text: 'Attendance Summary',
                                                                    position: 'bottom'
                                                                }
                                                            }
                                                        }
                                                    }"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card soft-card mt-3 p-3">
                                <h6 class="fw-semibold">My Subjects</h6>

                                <t t-foreach="state.teacher_activities.subjects" t-as="subject" t-key="subject.id">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span t-esc="subject.name" class="task-item"/>
                                        <span class="badge bg-success">Schedule</span>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>