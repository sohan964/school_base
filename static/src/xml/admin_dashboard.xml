<templates xml:space="preserve">
    <t t-name="school_base.SchoolAdminDashboard" school_base="1">
        <div class="vh-100 overflow-auto " >
            <div class="row">
                <!-- ✅ Main Content -->
                <div class="col-12 col-md-10 mx-auto p-4">
                    <div class="d-flex justify-content-between mb-4">
                        <h3>Dashboard</h3>
                        <div>👤 Admin</div>
                    </div>
                    <!-- Your content here -->
                    <div class="row g-3 mb-4">
                        <KpiCard t-props="{
                            bg: 'bg-primary',
                            name: 'Total Students',
                            value: state.students.value,
                            icon: 'bi-people'
                        }"/>
                        <KpiCard t-props="{
                            bg: 'bg-success',
                            name: 'Total Teachers',
                            value: state.teachers.value,
                            icon: 'bi-person-badge'
                        }"/>
                        <KpiCard t-props="{
                            bg: 'bg-warning',
                            name: 'Total Classes',
                            value: state.classes.value,
                            icon: 'bi-book'
                        }"/>
                        <KpiCard t-props="{
                            bg: 'bg-danger',
                            name: 'Total Departments',
                            value: state.departments.value,
                            icon: 'bi-building'
                        }"/>
                    </div>
                    <!-- ACADEMIC YEAR -->
                    <div class="card soft-card mb-3 shadow-sm">
                        <div class="card-body d-flex flex-wrap align-items-center justify-content-between">
                            <!-- Left: Title -->
                            <div class="d-flex align-items-center">
                                <i class="bi bi-calendar3 fs-4 text-primary me-2"></i>
                                <h6 class="mb-0 fw-bold" t-esc="state?.accademic_year?.name"/>
                            </div>
                            <!-- Right: Dates -->
                            <div class="d-flex gap-2">
                                <span class="badge bg-primary">
                                    Start:
                                    <span t-esc="state.accademic_year.date_start"/>
                                </span>
                                <span class="badge bg-success">
                                    End:
                                    <span t-esc="state.accademic_year.date_end"/>
                                </span>
                            </div>
                        </div>
                    </div>
                    <!-- Todays Academic Activities -->
                    <div class="row g-3">
                        <!-- LEFT COLUMN -->
                        <div class="col-lg-6">
                            <!-- TODAY ACTIVITY -->
                            <div class="card soft-card mb-3">
                                <div class="card-header">Today's Academic Activity</div>
                                <div class="p-3">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="status-box bg-warning">
                                            <i class="bi bi-calendar"></i>
                                        </div>
                                        <div class="ms-3 flex-grow-1">Classes Scheduled Today</div>
                                        <strong t-esc="state.todayacademicactivities.classes_scheduled"></strong>
                                    </div>
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="status-box bg-success">
                                            <i class="bi bi-check"></i>
                                        </div>
                                        <div class="ms-3 flex-grow-1">Classes Completed</div>
                                        <strong t-esc="state.todayacademicactivities.classes_completed"></strong>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <div class="status-box bg-danger">
                                            <i class="bi bi-exclamation"></i>
                                        </div>
                                        <div class="ms-3 flex-grow-1">Classes Pending</div>
                                        <strong t-esc="state.todayacademicactivities.classes_pendding"></strong>
                                    </div>
                                </div>
                            </div>
                            <!-- teacher alart -->
                            <div class="card soft-card mb-3">
                                <div class="card-header d-flex justify-content-between">
                                    Pending Work / Alerts
                                    <span class="text-primary">View All</span>
                                </div>
                                <div class="p-3">
                                    <div class="alert-item">❌ 3 Classes without Teacher</div>
                                    <div class="alert-item">❌ 6 Attendance Pending</div>
                                    <div class="alert-item">❌ 5 Students without Enrollment</div>
                                    <div class="alert-item">❌ 2 Exams Missing</div>
                                </div>
                            </div>
                        </div>
                        <!-- right columns -->
                        <div class="col-lg-6">
                            <!-- ATTENDANCE -->
                            <div class="card soft-card mb-3">
                                <div class="card-header">Attendance Summary</div>
                                <!-- <div class="p-3 row text-center g-2">
                                    <div class="col">
                                        <div class="mini-card bg-success">Present
                                            <br/>
                                            <strong id="presentCount">920</strong>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <div class="mini-card bg-danger">Absent
                                            <br/>
                                            <strong id="absentCount">55</strong>
                                        </div>
                                    </div>
                                    <div class="col">
                                        <div class="mini-card bg-warning">Late
                                            <br/>
                                            <strong id="lateCount">15</strong>
                                        </div>
                                    </div>
                                </div> -->
                                <div class="p-3 text-center">
                                    <ChartRenderer />
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>