<templates xml:space="preserve">
    <t t-name="school_base.SchoolAdminDashboard" school_base="1">
        <div class="vh-100 overflow-auto " >
            <div class="row">
                <!-- ✅ Main Content -->
                <div class="col-12 col-md-10 mx-auto p-4">
                    <div class="d-flex justify-content-between mb-4">
                        <h3>Dashboard</h3>
                        <div>👤 Admin</div>
                    </div>
                    <!-- Your content here -->
                    <div class="row g-3 mb-4">
                        <KpiCard t-props="{
                            bg: 'bg-primary',
                            name: 'Total Students',
                            value: state.students.value,
                            icon: 'bi-people'
                        }"/>
                        <KpiCard t-props="{
                            bg: 'bg-success',
                            name: 'Total Teachers',
                            value: state.teachers.value,
                            icon: 'bi-person-badge'
                        }"/>
                        <KpiCard t-props="{
                            bg: 'bg-warning',
                            name: 'Total Classes',
                            value: state.classes.value,
                            icon: 'bi-book'
                        }"/>
                        <KpiCard t-props="{
                            bg: 'bg-danger',
                            name: 'Total Departments',
                            value: state.departments.value,
                            icon: 'bi-building'
                        }"/>
                    </div>
                    <!-- ACADEMIC YEAR -->
                    <div class="card soft-card mb-3 shadow-sm">
                        <div class="card-body d-flex flex-wrap align-items-center justify-content-between">
                            <!-- Left: Title -->
                            <div class="d-flex align-items-center">
                                <i class="bi bi-calendar3 fs-4 text-primary me-2"></i>
                                <h6 class="mb-0 fw-bold" t-esc="state?.accademic_year?.name"/>
                            </div>
                            <!-- Right: Dates -->
                            <div class="d-flex gap-2">
                                <span class="badge bg-primary">
                                    Start:
                                    <span t-esc="state.accademic_year.date_start"/>
                                </span>
                                <span class="badge bg-success">
                                    End:
                                    <span t-esc="state.accademic_year.date_end"/>
                                </span>
                            </div>
                        </div>
                    </div>
                    <!-- Todays Academic Activities -->
                    <div class="row g-3">
                        <!-- LEFT COLUMN -->
                        <div class="col-lg-6">
                            <!-- TODAY ACTIVITY -->
                            <div class="card soft-card mb-3">
                                <div class="card-header">Today's Academic Activity</div>
                                <div class="p-3">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="status-box bg-warning">
                                            <i class="bi bi-calendar"></i>
                                        </div>
                                        <div class="ms-3 flex-grow-1">Classes Scheduled Today</div>
                                        <strong t-esc="state.todayacademicactivities.classes_scheduled"></strong>
                                    </div>
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="status-box bg-success">
                                            <i class="bi bi-check"></i>
                                        </div>
                                        <div class="ms-3 flex-grow-1">Classes Completed</div>
                                        <strong t-esc="state.todayacademicactivities.classes_completed"></strong>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <div class="status-box bg-danger">
                                            <i class="bi bi-exclamation"></i>
                                        </div>
                                        <div class="ms-3 flex-grow-1">Classes Pending</div>
                                        <strong t-esc="state.todayacademicactivities.classes_pendding"></strong>
                                    </div>
                                </div>
                            </div>
                            <!-- teacher alart -->
                            <div class="card soft-card border-0">

                                <div class="card-header d-flex justify-content-between align-items-center">

                                    <h5 class="mb-0">
                                        Current Classes
                                    </h5>

                                    <div class="d-flex gap-2">

                                        <!-- Day -->

                                        <select
                                            class="form-select form-select-sm"
                                            style="width:140px;"
                                            t-on-change="onDayChange">

                                            <option
                                                t-foreach="state.adminRoutineStats.days"
                                                t-as="day"
                                                t-key="day.id"
                                                t-att-value="day.id"
                                                t-att-selected="day.id === state.adminRoutineStats.dayId">

                                                <t t-esc="day.name"/>

                                            </option>

                                        </select>

                                        <!-- Slot -->

                                        <select
                                            class="form-select form-select-sm"
                                            style="width:170px;"
                                            t-on-change="onSlotChange">

                                            <option
                                                t-foreach="state.adminRoutineStats.slots"
                                                t-as="slot"
                                                t-key="slot.id"
                                                t-att-value="slot.id"
                                                t-att-selected="slot.id === state.adminRoutineStats.slotId">

                                                <t t-esc="slot.name"/>

                                            </option>

                                        </select>

                                        <span class="badge bg-primary">

                                            <t t-esc="state.adminRoutineStats.total"/>

                                        </span>

                                    </div>

                                </div>

                                <div class="card-body p-0">

                                    <table class="table table-hover mb-0">

                                        <thead>

                                            <tr>
                                                <th>Teacher</th>
                                                <th>Subject</th>
                                                <th>Class</th>
                                                <th>Section</th>
                                            </tr>

                                        </thead>

                                        <tbody>

                                            <tr
                                                t-if="!state.adminRoutineStats.routines.length">

                                                <td
                                                    colspan="4"
                                                    class="text-center text-muted">

                                                    No classes found

                                                </td>

                                            </tr>

                                            <tr
                                                t-foreach="state.adminRoutineStats.routines"
                                                t-as="routine"
                                                t-key="routine.id">

                                                <td>
                                                    <t t-esc="routine.teacher_id[1]"/>
                                                </td>

                                                <td>
                                                    <t t-esc="routine.subject_id[1]"/>
                                                </td>

                                                <td>
                                                    <t t-esc="routine.class_id[1]"/>
                                                </td>

                                                <td>
                                                    <t t-esc="routine.section_id[1]"/>
                                                </td>

                                            </tr>

                                        </tbody>

                                    </table>

                                </div>

                            </div>
                        </div>
                        <!-- right columns -->
                        <div class="col-lg-6">
                            <!-- ATTENDANCE -->
                            <div class="card soft-card mb-3">
                                <div class="card-header">Attendance Summary</div>
                                <div class=" p-3 text-center row">
                                    
                                    <ChartRenderer t-props="{
                                        type: 'doughnut',
                                        data: {
                                            labels: ['Present', 'Absent', 'Late'],
                                            datasets: [{
                                                label: 'Attendance '+ state.attendance_chart.total,
                                                data: [
                                                    state.attendance_chart.present,
                                                    state.attendance_chart.absent,
                                                    state.attendance_chart.late
                                                ],
                                                backgroundColor: [
                                                    '#28a745',
                                                    '#dc3545',
                                                    '#ffc107'
                                                ]
                                            }]
                                        },
                                        options: {
                                            plugins: {
                                                legend: { position: 'bottom' },
                                                title: { display: true, text: 'Attendance Summary', position: 'bottom'}
                                            }
                                        }
                                    }"/>

                                    <ChartRenderer t-props="{
                                        type: 'pie',
                                        data: {
                                            labels: ['Present', 'Absent'],
                                            datasets: [{
                                                label: 'Attendance Parcentage 100%',
                                                data: [
                                                    state.attendance_chart.attendance_parcent,
                                                    100 - state.attendance_chart.attendance_parcent,
                                                    
                                                ],
                                                backgroundColor: [
                                                    '#28a745',
                                                    '#dc3545',
                                                    
                                                ]
                                            }]
                                        },
                                        options: {
                                            plugins: {
                                                legend: { position: 'bottom' },
                                                title: { display: true, text: 'Attendance Parcentage', position: 'bottom'}
                                            }
                                        }
                                    }"/>
                                </div>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="card soft-card p-3 text-center">Exam Overview</div>
                                </div>

                                <div class="col-md-6">
                                    <div class="card soft-card p-3 text-center">Teacher Workload</div>
                                </div>

                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
    </t>
</templates>