<templates xml:space="preserve">
    <t t-name="school_base.SchoolStudentDashboard">
        <div class="vh-100 overflow-auto">
            <div class="row">
                <div class="col-12 col-md-10 mx-auto p-4">
                    <!-- Header -->
                    <div class="card soft-card shadow-sm border-0 mb-4">
                        <div class="card-body d-flex align-items-center">
                            <img
                                t-att-src="state.studentInfo.image
                                    ? 'data:image/jpeg;base64,' + state.studentInfo.image
                                    : 'https://via.placeholder.com/60'"
                                class="rounded-circle border shadow-sm me-3"
                                width="60"
                                height="60"
                            />
                            <div class="flex-grow-1">
                                <h2 class="fw-bold mb-1">
                                    Welcome Back,
                                    <span t-esc="state.studentInfo.name"/> 👋
                                </h2>
                                <p class="text-muted mb-1">
                                    <span t-esc="state.studentInfo.email"/>
                                </p>
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    <span class="badge bg-primary text-white">
                                        Dept:
                                        <t t-esc="state.academicStats.department[1]"/>
                                    </span>
                                    <span class="badge bg-info text-white">
                                        Class:
                                        <t t-esc="state.academicStats.class[1]"/>
                                    </span>
                                    <span class="badge bg-warning text-white">
                                        Section:
                                        <t t-esc="state.academicStats.section[1]"/>
                                    </span>
                                    <span
                                        t-if="state.studentInfo.active "
                                        class="badge bg-success text-white">
                                        Active
                                    </span>
                                    <span
                                        t-if="!state.studentInfo.active"
                                        class="badge bg-danger text-white">
                                        Inactive
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- ACADEMIC YEAR -->
                    <div class="card soft-card mb-3 shadow-sm">
                        <div class="card-body d-flex flex-wrap align-items-center justify-content-between">
                            <!-- Left: Title -->
                            <div class="d-flex align-items-center">
                                <i class="bi bi-calendar3 fs-4 text-primary me-2"></i>
                                <h6 class="mb-0 fw-bold" t-esc="state?.academic_year?.name"/>
                            </div>
                            <!-- Right: Dates -->
                            <div class="d-flex gap-2">
                                <span class="badge bg-primary">
                                        Start:
                                    <span t-esc="state?.academic_year?.date_start"/>
                                    </span>
                                <span class="badge bg-success">
                                        End:
                                    <span t-esc="state?.academic_year?.date_end"/>
                                    </span>
                            </div>
                        </div>
                    </div>
                    <!-- KPI Cards -->
                    <div class="row g-3 mb-4">
                        <KpiCard t-props="{
                                bg: 'bg-primary',
                                name: 'Average Attendances',
                                value: state.attendanceStats.attendancePercentage + '%',
                                icon: 'bi-person-check'
                            }"/>
                        <KpiCard t-props="{
                                bg: 'bg-success',
                                name: 'Average Marks',
                                value: state.resultStats.averagePercentage +'%',
                                icon: 'bi-award'
                            }"/>
                        <KpiCard t-props="{
                                bg: 'bg-warning',
                                name: 'Upcoming Exams',
                                value: state.examStats.totalExam,
                                icon: 'bi-pencil-square'
                            }"/>
                        <KpiCard t-props="{
                                bg: 'bg-danger',
                                name: 'Subjects',
                                value: state.subjectStats.totalSubject,
                                icon: 'bi-book'
                            }"/>
                    </div>
                    <!-- Today's Classes + Upcoming Exams -->
                    <div class="row g-3 mb-4">
                        <!-- Today's Classes -->
                        <div class="col-lg-8">
                            <div class="card soft-card border-0">
                                <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">
                                            Today's Classes
                                        </h5>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge text-white bg-primary">
                                            <t t-esc="state.routineStats.today"/>
                                        </span>
                                        <select class="form-select form-select-sm"
                                                    style="width: 120px;"
                                                    t-on-change="onRoutineViewChange">
                                            <option value="today" selected="selected">
                                                    Today
                                                </option>
                                            <option value="week">
                                                    This Week
                                                </option>
                                        </select>
                                        <button
                                            class="btn btn-primary btn-sm"
                                            style="padding:2px 8px;font-size:12px;"
                                            t-on-click="downloadRoutine">
                                            Print
                                        </button>
                                    </div>
                                </div>
                                <div class="card-body p-0">
                                    <table class="table table-hover mb-0">
                                        <thead>
                                            <tr>
                                                <th t-if="state.routineStats.viewMode === 'week'">
                                                        Day
                                                    </th>
                                                <th>Time</th>
                                                <th>Subject</th>
                                                <th>Teacher</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-if="!state.routineStats.routine.length">
                                                <td colspan="3" class="text-center text-muted">
                                                        No classes scheduled today
                                                    </td>
                                            </tr>
                                            <tr
                                                    t-foreach="state.routineStats.routine"
                                                    t-as="routine"
                                                    t-key="routine.id"
                                                >
                                                <td t-if="state.routineStats.viewMode === 'week'">
                                                    <t t-esc="routine.day_id[1]"/>
                                                </td>
                                                <td>
                                                    <t t-esc="routine.slot_id[1]"/>
                                                </td>
                                                <td>
                                                    <t t-esc="routine.subject_id[1]"/>
                                                </td>
                                                <td>
                                                    <t t-esc="routine.teacher_id[1]"/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="row g-3 mt-1">
                                <div class="col-md-6 ">
                                    <div class="card soft-card border-0">
                                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                                            <h5 class="mb-0">
                                                Upcoming Exams
                                            </h5>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge text-white bg-primary">
                                                    <t t-esc="state.examStats.totalExam"/>
                                                </span>
                                                <select class="form-select form-select-sm"
                                                        style="width: 120px;"
                                                        t-on-change="onExamRoutineChange">
                                                    <option value="">
                                                            Current Month
                                                        </option>
                                                    <option
                                                            t-foreach="state.resultStats.exams"
                                                            t-as="exam"
                                                            t-key="exam.id"
                                                            t-att-value="exam.id">
                                                        <t t-esc="exam.name"/>
                                                    </option>
                                                </select>
                                                <button
                                                    class="btn btn-primary btn-sm"
                                                    style="padding:2px 8px;font-size:12px;"
                                                    t-on-click="downloadExamRoutine">
                                                    Print
                                                </button>
                                            </div>
                                        </div>
                                        <div class="card-body p-0">
                                            <table class="table table-hover mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Subject</th>
                                                        <th>Date</th>
                                                        <th>Time Slot</th>
                                                        <th>Full Marks</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-if="!state.examStats.exams.length">
                                                        <td colspan="4" class="text-center text-muted">
                                                            No upcoming exams
                                                        </td>
                                                    </tr>
                                                    <tr
                                                        t-foreach="state.examStats.exams"
                                                        t-as="exam"
                                                        t-key="exam.id"
                                                    >
                                                        <td>
                                                            <t t-esc="exam.subject_id[1]"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="exam.exam_date"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="exam.exam_time_slot_id ? exam.exam_time_slot_id[1] : ''"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="exam.full_marks"/>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 ">
                                    <div class="card soft-card border-0">
                                        <div class="card-header bg-white d-flex justify-content-between align-items-center">
                                            <h5 class="mb-0">
                                                Results
                                            </h5>
                                            <div class="d-flex align-items-center gap-2">
                                                <select class="form-select form-select-sm"
                                                    style="width: 120px;"
                                                    t-on-change="onExamChange">
                                                    <option value="">
                                                        All Exams
                                                    </option>
                                                    <option
                                                        t-foreach="state.resultStats.exams"
                                                        t-as="exam"
                                                        t-key="exam.id"
                                                        t-att-value="exam.id">
                                                        <t t-esc="exam.name"/>
                                                    </option>
                                                </select>
                                                <button
                                                    class="btn btn-primary btn-sm"
                                                    style="padding:2px 8px;font-size:12px;"
                                                    t-on-click="downloadResult">
                                                    Print
                                                </button>
                                            </div>
                                        </div>
                                        <div class="card-body p-0">
                                            <table class="table table-hover mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Subject</th>
                                                        <th>Marks</th>
                                                        <th>%</th>
                                                        <th>Grade</th>
                                                        <th>GPA</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-if="!state.resultStats.subjectResults.length">
                                                        <td colspan="5" class="text-center text-muted">
                                                            No results found
                                                        </td>
                                                    </tr>
                                                    <tr
                                                        t-foreach="state.resultStats.subjectResults"
                                                        t-as="result"
                                                        t-key="result.subject_id"
                                                    >
                                                        <td>
                                                            <t t-esc="result.subject_name"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="result.obtained"/> /
                                                            <t t-esc="result.full_marks"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="result.percentage"/>%
                                                        </td>
                                                        <td>
                                                            <span class="badge bg-success">
                                                                <t t-esc="result.grade"/>
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <t t-esc="result.gpa"/>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="card soft-card mb-2 border-0">
                                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">
                                        Attendance Summary 
                                    </h5>
                                    <span class="badge text-white bg-primary">
                                        <t t-esc="state.attendanceStats.attendancePercentage"/>%
                                    </span>
                                </div>
                                <ChartRenderer t-props="{
                                        type: 'doughnut',
                                        data: {
                                            labels: ['Present', 'Absent', 'Late'],
                                            datasets: [{
                                                label: 'Attendance ' + state.attendanceStats.total,
                                                data: [
                                                    state.attendanceStats.present,
                                                    state.attendanceStats.absent,
                                                    state.attendanceStats.late
                                                ],
                                                backgroundColor: [
                                                    '#28a745',
                                                    '#dc3545',
                                                    '#ffc107'
                                                ]
                                            }]
                                        },
                                        options: {
                                            plugins: {
                                                legend: { position: 'bottom' },
                                                title: { display: true, text: 'Attendance Summary', position: 'bottom'}
                                            }
                                        }
                                    }"/>
                            </div>
                            <div class="card soft-card border-0">
                                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">
                                        Attendance Summary
                                    </h5>
                                    <span class="badge text-white bg-primary">
                                        <t t-esc="state.attendanceStats.total"/>
                                    </span>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Present</span>
                                        <span class="text-success" t-esc="state.attendanceStats.present"/>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Absent</span>
                                        <span class="text-danger" t-esc="state.attendanceStats.absent"/>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span>Late</span>
                                        <span class="text-warning" t-esc="state.attendanceStats.late"/>
                                    </div>
                                </div>
                            </div>
                            <!-- about payments -->
                            <div class="card my-2 soft-card border-0">

                                <div class="card-header bg-white d-flex justify-content-between align-items-center">

                                    <h5 class="mb-0">
                                        Outstanding Fees
                                    </h5>

                                    <span class="badge bg-danger">
                                        Total Due:
                                        <t t-esc="state.paymentStats.totalDue"/>
                                    </span>

                                </div>

                                <div class="card-body p-0">

                                    <div class="table-responsive">

                                        <table class="table table-hover align-middle mb-0">

                                            <thead class="table-light">

                                                <tr>
                                                    <th>Month</th>
                                                    <th class="text-end">Total</th>
                                                    <th class="text-end">Paid</th>
                                                    <th class="text-end">Due</th>
                                                    <th class="text-center">Status</th>
                                                    <th class="text-center">Action</th>
                                                </tr>

                                            </thead>

                                            <tbody>

                                                <tr t-if="!state.paymentStats.dues.length">
                                                    <td colspan="6"
                                                        class="text-center text-muted py-4">
                                                        No outstanding fees found.
                                                    </td>
                                                </tr>

                                                <tr
                                                    t-foreach="state.paymentStats.dues"
                                                    t-as="fee"
                                                    t-key="fee.id">

                                                    <td>
                                                        <t t-esc="fee.batch_id[1]"/>
                                                    </td>

                                                    <td class="text-end">
                                                        
                                                        <t t-esc="fee.paid_amount + fee.due_amount"/>
                                                    </td>

                                                    <td class="text-end text-success fw-semibold">
                                                        
                                                        <t t-esc="fee.paid_amount"/>
                                                    </td>

                                                    <td class="text-end text-danger fw-semibold">
                                                        
                                                        <t t-esc="fee.due_amount"/>
                                                    </td>

                                                    <td class="text-center">

                                                        <span
                                                            t-att-class="{
                                                                'badge bg-danger': fee.state === 'unpaid',
                                                                'badge bg-warning text-dark': fee.state === 'partial'
                                                            }">

                                                            <t t-esc="fee.state"/>

                                                        </span>

                                                    </td>

                                                    <td class="text-center">

                                                        <button
                                                            class="btn btn-success btn-sm"
                                                            style="padding:2px 8px;font-size:12px;">

                                                            <!-- <i class="bi bi-credit-card me-1"/> -->

                                                            Pay

                                                        </button>

                                                    </td>

                                                </tr>

                                            </tbody>

                                        </table>

                                    </div>

                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>