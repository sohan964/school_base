<odoo>
    <data>
        <!-- Define the sequence for Academic Year without numbering -->
        <record id="seq_chool_academic_year" model="ir.sequence">
            <field name="name">Academic Year</field>
            <field name="code">school.academic.year</field>
            <field name="prefix">Y_%(year)s</field>  <!-- Prefix with current year -->
            <field name="padding" eval="0"/>           <!-- No padding, as we don't need numbers -->
            <field name="company_id" eval="False"/>
            <field name="number_next" eval="1"/>       <!-- Number is not relevant, just for initialization -->
            <field name="number_increment" eval="1"/>
        </record>

        <record id="seq_school_fee_payment" model="ir.sequence">
            <field name="name">School Fee Payment</field>
            <field name="code">school.fee.payment</field>
            <field name="prefix">PAY/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>