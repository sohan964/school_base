<odoo>
    <data>
        <!-- create category -->
        <record id="module_category_school_management" model="ir.module.category">
            <field name="name">School Management</field>
            <field name="sequence">25</field>
        </record>
        <!-- Privilege is need to create must from and after odoo19-->
        <record model="res.groups.privilege" id="privilege_school_management">
            <field name="name">School Management</field>
            <field name="category_id" ref="module_category_school_management"/>
        </record>
        <record id="group_school_admin" model="res.groups">
            <field name="name">School Admin</field>
            <field name="privilege_id" ref="privilege_school_management" />
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Admin can have access all over the system</field>
        </record>
        <record id="group_school_teacher" model="res.groups">
            <field name="name">School Teacher</field>
            <field name="privilege_id" ref="privilege_school_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Teacher can have access about this part</field>
        </record>
        <record id="group_school_student" model="res.groups">
            <field name="name">School Student</field>
            <field name="privilege_id" ref="privilege_school_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Student can have access about this parts</field>
        </record>
        <record id="group_school_accountant" model="res.groups">
            <field name="name">School Accountant</field>
            <field name="privilege_id" ref="privilege_school_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Accountant can have access about this parts</field>
        </record>
        <record id="group_school_admission_officer" model="res.groups">
            <field name="name">School Admission Officer</field>
            <field name="privilege_id" ref="privilege_school_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Admission Officer can have access about this parts</field>
        </record>

        
    </data>
</odoo>