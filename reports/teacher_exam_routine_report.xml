<odoo>

    <template id="teacher_exam_routine_report">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="doc">

                <t t-call="web.external_layout">

                    <div class="page">

                        <h2 style="text-align:center;">
                            Teacher Exam Routine
                        </h2>

                        <h4>
                            Teacher:
                            <span t-esc="doc.name"/>
                        </h4>

                        <br/>

                        <table
                            class="table table-bordered">

                            <thead>

                                <tr>

                                    <th>Exam</th>
                                    <th>Subject</th>
                                    <th>Class</th>
                                    <th>Date</th>
                                    <th>Time Slot</th>
                                    <th>Marks</th>

                                </tr>

                            </thead>

                            <tbody>

                                <tr
                                    t-foreach="exams"
                                    t-as="exam">

                                    <td>
                                        <span
                                            t-esc="exam.exam_id.name"/>
                                    </td>

                                    <td>
                                        <span
                                            t-esc="exam.subject_id.name"/>
                                    </td>

                                    <td>
                                        <span
                                            t-esc="exam.class_id.name"/>
                                    </td>

                                    <td>
                                        <span
                                            t-esc="exam.exam_date"/>
                                    </td>

                                    <td>
                                        <span
                                            t-esc="exam.exam_time_slot_id.name"/>
                                    </td>

                                    <td>
                                        <span
                                            t-esc="exam.full_marks"/>
                                    </td>

                                </tr>

                            </tbody>

                        </table>

                    </div>

                </t>

            </t>

        </t>

    </template>

</odoo>