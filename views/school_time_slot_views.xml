<odoo>
    <data>

        <!-- List View -->
        <record id="view_school_time_slot_list" model="ir.ui.view">
            <field name="name">school.time.slot.list</field>
            <field name="model">school.time.slot</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="start_time" widget="float_time"/>
                    <field name="end_time" widget="float_time"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_school_time_slot_form" model="ir.ui.view">
            <field name="name">school.time.slot.form</field>
            <field name="model">school.time.slot</field>
            <field name="arch" type="xml">
                <form string="Time Slot">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="start_time" widget="float_time"/>
                                <field name="end_time" widget="float_time"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_school_time_slot" model="ir.actions.act_window">
            <field name="name">Time Slots</field>
            <field name="res_model">school.time.slot</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Slots
                </p>
            </field>
        </record>

    </data>
</odoo>