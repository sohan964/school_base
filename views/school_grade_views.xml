<odoo>

     <!-- List View -->
    <record id="view_school_grade_list" model="ir.ui.view">
        <field name="name">school.grade.list</field>
        <field name="model">school.grade</field>
        <field name="arch" type="xml">
            <list string="Grades">
                <field name="name"/>
                <field name="min_mark"/>
                <field name="max_mark"/>
                <field name="gpa"/>
                <field name="remarks"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_grade_form" model="ir.ui.view">
        <field name="name">school.grade.form</field>
        <field name="model">school.grade</field>
        <field name="arch" type="xml">
            <form string="Grade">
                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group string="Grade Information">
                        <group>
                            <field name="min_mark"/>
                            <field name="max_mark"/>
                        </group>

                        <group>
                            <field name="gpa"/>
                            <field name="remarks"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_grade" model="ir.actions.act_window">
        <field name="name">Exam Result Grade</field>
        <field name="res_model">school.grade</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create new a grade
            </p>
        </field>
    </record>
</odoo>