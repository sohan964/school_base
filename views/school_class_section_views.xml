<odoo>
    <data>

        <!-- List View -->
        <record id="view_school_class_section_list" model="ir.ui.view">
            <field name="name">school.class.section.list</field>
            <field name="model">school.class.section</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="class_id"/>
                    <field name="department_id" />
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_school_class_section_form" model="ir.ui.view">
            <field name="name">school.class.section.form</field>
            <field name="model">school.class.section</field>
            <field name="arch" type="xml">
                <form string="Class Section">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="class_id"/>
                                <field name="department_id" />
                                <field name="active"/>
                            </group>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_school_class_section" model="ir.actions.act_window">
            <field name="name">Class Sections of School</field>
            <field name="res_model">school.class.section</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    create a new section
                </p>
            </field>
        </record>

    </data>
</odoo>