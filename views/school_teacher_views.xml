<odoo>

    <!-- List View -->
    <record id="view_school_teacher_list" model="ir.ui.view">
        <field name="name">school.teacher.list</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_teacher_form" model="ir.ui.view">
        <field name="name">school.teacher.form</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <form string="Teacher">
                <sheet>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="user_id" />
                            <field name="department_id"/>
                            <field name="designation"/>
                            <field name="joining_date"/>
                            <field name="active"/>
                        </group>

                        <group>
                            <field name="image"
                                   widget="image"
                                   class="oe_avatar"
                                   nolabel="1"
                                   options="{'size': [120,120]}"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Contact Information">
                            <group>
                                <field name="email"/>
                                <field name="phone"/>
                                <field name="address"/>
                            </group>
                        </page>

                        <page string="Personal Information">
                            <group>
                                <field name="gender"/>
                                <field name="date_of_birth"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_teacher" model="ir.actions.act_window">
        <field name="name">School Teacher</field>
        <field name="res_model">school.teacher</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Teacher
            </p>
        </field>
    </record>
</odoo>