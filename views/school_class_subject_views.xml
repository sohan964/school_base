<odoo>
    <data>

        <!-- List View -->
        <record id="view_school_class_subject_list" model="ir.ui.view">
            <field name="name">school.class.subject.list</field>
            <field name="model">school.class.subject</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="department_ids" widget="many2many_tags" />
                    <field name="class_ids" widget="many2many_tags"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_school_class_subject_form" model="ir.ui.view">
            <field name="name">school.class.subject.form</field>
            <field name="model">school.class.subject</field>
            <field name="arch" type="xml">
                <form string="Class Subject">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="department_ids" widget="many2many_tags" />
                                <field name="class_ids" widget="many2many_tags"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_school_class_subject" model="ir.actions.act_window">
            <field name="name">Class Subjects</field>
            <field name="res_model">school.class.subject</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    create a new Subject
                </p>
            </field>
        </record>

    </data>
</odoo>