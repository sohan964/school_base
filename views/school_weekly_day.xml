<odoo>
    <record id="view_school_weekly_day_list" model="ir.ui.view">
        <field name="name">school.weekly.day.list</field>
        <field name="model">school.weekly.day</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_school_weekly_day_form" model="ir.ui.view">
        <field name="name">school.weekly.day.form</field>
        <field name="model">school.weekly.day</field>
        <field name="arch" type="xml">
            <form string="Day of Week">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_school_weekly_day" model="ir.actions.act_window">
        <field name="name">Days of Week</field>
        <field name="res_model">school.weekly.day</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>