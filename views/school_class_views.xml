<odoo>
    <data>

        <!-- List View -->
        <record id="view_school_class_list" model="ir.ui.view">
            <field name="name">school.class.list</field>
            <field name="model">school.class</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_school_class_form" model="ir.ui.view">
            <field name="name">school.class.form</field>
            <field name="model">school.class</field>
            <field name="arch" type="xml">
                <form string="Class">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="active"/>
                            </group>
                        </group>

                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_school_class" model="ir.actions.act_window">
            <field name="name">School Class</field>
            <field name="res_model">school.class</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create a class</p>
            </field>
        </record>

    </data>
</odoo>