<odoo>
    <!-- List View -->
    <record id="view_school_department_list" model="ir.ui.view">
        <field name="name">school.department.list</field>
        <field name="model">school.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <!-- Form View -->
    <record id="view_school_department_form" model="ir.ui.view">
        <field name="name">school.department.form</field>
        <field name="model">school.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <!-- Title + Image -->
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="logo" widget="image"
                               nolabel="1"
                               class="oe_avatar"
                               options="{'size': [120,120]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <group>
                                <field name="description"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_school_department" model="ir.actions.act_window">
        <field name="name">School Departments</field>
        <field name="res_model">school.department</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Department
            </p>
        </field>
    </record>
</odoo>