<odoo>

    <record id="view_school_student_attendance_list" model="ir.ui.view">
        <field name="name">school.student.attendance.list</field>
        <field name="model">school.student.attendance</field>
        <field name="arch" type="xml">
            <list>
                <field name="teacher_id"/>
                <field name="year_id"/>
                <field name="date"/>
                <field name="day_id"/>
                <field name="slot_id"/>
                <field name="teacher_assignment_id"/>
            </list>
        </field>
    </record>

    <record id="view_school_student_attendance_form" model="ir.ui.view">
        <field name="name">school.student.attendance.form</field>
        <field name="model">school.student.attendance</field>
        <field name="arch" type="xml">
            <form string="Student Attendance">
                <sheet>

                    <group>
                        <group>
                            <field name="teacher_id"/>
                            <field name="year_id"/>
                            <field name="date"/>
                        </group>

                        <group>
                            <field name="day_id"/>
                            <field name="slot_id"/>
                            <field name="teacher_assignment_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Students">
                            <field name="attendance_line_ids">
                                <list editable="bottom" create="false">
                                    <field name="enrollment_id" column_invisible="True"/>
                                    <field name="student_id" readonly="1"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>


    <record id="action_school_student_attendance" model="ir.actions.act_window" >
        <field name="name">Student Class Attendance</field>
        <field name="res_model">school.student.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Take an attendance
            </p>
        </field>
    </record>
</odoo>