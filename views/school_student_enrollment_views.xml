<odoo>
    <data>

        <!-- List View -->
        <record id="view_school_student_enrollment_list" model="ir.ui.view">
            <field name="name">school.student.enrollment.list</field>
            <field name="model">school.student.enrollment</field>
            <field name="arch" type="xml">
                <list>
                    <field name="student_id"/>
                    <field name="year_id"/>
                    <field name="department_id"/>
                    <field name="class_id"/>
                    <field name="section_id"/>
                    <field name="roll_no"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_school_student_enrollment_form" model="ir.ui.view">
            <field name="name">school.student.enrollment.form</field>
            <field name="model">school.student.enrollment</field>
            <field name="arch" type="xml">
                <form string="Student Enrollment">
                    <sheet>

                        <!-- Title -->
                        <div class="oe_title">
                            <h1>
                                <field name="student_id" placeholder="Student"/>
                            </h1>
                        </div>

                        <!-- Academic Info -->
                        <group string="Academic Information">
                            <group>
                                <field name="year_id"/>
                                <field name="department_id"/>
                                <field name="class_id"/>
                                <field name="section_id"/>
                            </group>
                            <group>
                                <field name="roll_no"/>
                                <field name="state"/>
                            </group>
                        </group>

                        <!-- Dates -->
                        <group string="Enrollment Period">
                            <group>
                                <field name="date_start"/>
                                <field name="date_end"/>
                            </group>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="action_school_student_enrollment" model="ir.actions.act_window">
            <field name="name">Student Enrollment</field>
            <field name="res_model">school.student.enrollment</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Add an enrollment of Student
                </p>
            </field>
        </record>

    </data>
</odoo>