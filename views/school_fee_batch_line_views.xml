<odoo>
    <record id="view_school_fee_batch_line_list"
        model="ir.ui.view">
        <field name="name">school.fee.batch.line.list</field>
        <field name="model">school.fee.batch.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="student_id"/>
                <field name="batch_id"/>
                <field name="department_id"/>
                <field name="class_id"/>
                <field name="amount"/>
                <field name="paid_amount"/>
                <field name="due_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="view_school_fee_batch_line_form"
        model="ir.ui.view">
        <field name="name">school.fee.batch.line.form</field>
        <field name="model">school.fee.batch.line</field>
        <field name="arch" type="xml">
            <form>

                <header>

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="unpaid,partial,paid"/>

                </header>

                <sheet>

                    <group>
                        <group>
                            <field name="student_id"
                                readonly="1"/>
                            <field name="enrollment_id"
                                readonly="1"/>
                            <field name="batch_id"
                                readonly="1"/>
                        </group>

                        <group>
                            <field name="department_id"
                                readonly="1"/>
                            <field name="class_id"
                                readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="amount"
                                readonly="1"/>
                            <field name="paid_amount" readonly="1"/>
                        </group>

                        <group>
                            <field name="due_amount"
                                readonly="1"/>
                        </group>
                    </group>

                </sheet>

            </form>
        </field>
    </record>

    <record id="action_school_fee_batch_line"
        model="ir.actions.act_window">
        <field name="name">Student Fees</field>
        <field name="res_model">school.fee.batch.line</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_school_fee_batch_line"
        name="Student Fees"
        parent="menu_school_fees"
        action="action_school_fee_batch_line"
        sequence="4"/>
</odoo>