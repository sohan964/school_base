<odoo>

    <!-- List View -->
    <record id="view_school_fee_payment_list"
            model="ir.ui.view">
        <field name="name">school.fee.payment.list</field>
        <field name="model">school.fee.payment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_id"/>
                <field name="fee_line_id"/>
                <field name="payment_date"/>
                <field name="payment_method_id"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_school_fee_payment_form"
            model="ir.ui.view">
        <field name="name">school.fee.payment.form</field>
        <field name="model">school.fee.payment</field>
        <field name="arch" type="xml">
            <form>

                <header>

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,paid,cancel"/>

                </header>

                <sheet>

                    <group>

                        <group>

                            <field name="name" readonly="1"/>

                            <field name="student_id"
                                   readonly="1"/>

                            <field name="fee_line_id"
                                   readonly="1"/>

                            <field name="payment_date"/>

                        </group>

                        <group>

                            <field name="payment_method_id"/>

                            <field name="amount"/>

                            <field name="reference"/>

                            <field name="transaction_id"/>

                        </group>

                    </group>

                    <group>

                        <field name="remarks"/>

                    </group>

                </sheet>

            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_school_fee_payment"
            model="ir.actions.act_window">
        <field name="name">Fee Payments</field>
        <field name="res_model">school.fee.payment</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>